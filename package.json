{
  "name": "form-snapshots",
  "version": "1.0.10",
  "description": "React + Dexie based form autosave & history snapshots library.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup form-snapshots/index.ts --format cjs,esm --dts --sourcemap --clean --out-dir dist",
    "prepare": "npm run build",
    "test": "pnpm run test:types && pnpm run test:unit",
    "test:types": "pnpm exec tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "sideEffects": false,
  "author": "",
  "license": "ISC"
}
